# Copy this to .env.deploy.local and fill in the values.
# .env.deploy.local is gitignored.
#
# scripts/cf-deploy.mjs reads this file and provisions everything that's
# automatable on Cloudflare. It does NOT push the website itself — that
# happens via git push (after CF Pages is wired to the repo) or via
# `wrangler pages deploy ./dist` for direct upload.

# --- Cloudflare ---
# Get this from: https://dash.cloudflare.com → right sidebar → Account ID
CF_ACCOUNT_ID=

# Get this from: https://dash.cloudflare.com/profile/api-tokens
# Create a custom token with these permissions:
#   Account / Cloudflare Pages / Edit
#   Account / Turnstile / Edit
#   Zone / DNS / Edit                 (only needed if you also want script-managed DNS)
#   Zone / Workers Routes / Edit
# Resources: include the AH account + the ahdesign.website zone
CF_API_TOKEN=

# Project + domain
CF_PAGES_PROJECT=ah
DOMAIN=ahdesign.website

# --- Turnstile ---
# Optional; if blank the script will create a Turnstile site for you and
# print the keys back. If you already created one in the dashboard, paste
# the keys here.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Gmail (form mailer) ---
GMAIL_USER=info@ahdesign.website
GMAIL_APP_PASSWORD=
# Optional — defaults to GMAIL_USER if blank
CONTACT_TO_EMAIL=

# --- GitHub OAuth App for the CMS ---
# Register at https://github.com/settings/developers (or skip CMS for v1)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
