{
  "name": "ah-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AHDesign website — Astro on Cloudflare Pages",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,astro,md,json,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,astro,md,json,css,html}\"",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:live": "cross-env BASE_URL=https://ahdesign.website playwright test",
    "test:visual:live:update": "cross-env BASE_URL=https://ahdesign.website playwright test --update-snapshots",
    "test:visual:ui": "playwright test --ui",
    "test:visual:report": "playwright show-report",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "cf:deploy": "node scripts/cf-deploy.mjs",
    "cf:upload": "npm run build && wrangler pages deploy ./dist --project-name=ah"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "astro": "^5.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.16.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8",
    "wrangler": "^4.87.0"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "worker-mailer": "^1.2.1"
  }
}
