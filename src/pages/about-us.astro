---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About us — AH-design"
  htmlClass="no-js vlt-is--about-us vlt-is--header-fullscreen vlt-is--footer-style-1 vlt-is--footer-fixed"
>
<!--Site overlay-->
	<div class="vlt-site-overlay"></div>
	<!--Main-->
	<main class="vlt-main">
		<!--Page content-->
		<div class="vlt-page-content">
			<!--Page title-->
			<div class="vlt-page-title vlt-page-title--style-4">
				<div class="container">
					<div class="row">
						<div class="col-md-7 offset-md-1">
							<h1 class="vlt-page-title__title">We create digital products
							</h1>
						</div>
						<div class="col-md-3">
							<div class="vlt-page-title__phantom-title lax" data-lax-translate-x="0 0, vw (vw*0.5)"
								data-lax-opacity="1 1, 250 0" data-lax-anchor=".vlt-page-title">
								About
							</div>
						</div>
					</div>
				</div>
			</div>
			<div id="content"></div>
			<div class="vlt-gap-120"></div>


			<!--========================= About us ==========================-->
			<section class="jarallax has-gray-color" style="background-color:black;">
				<!-- <img class="jarallax-img"
					src="static/img/careers-single-background.png" alt="" loading="lazy"> -->
				<div class="container">
					<div class="row">
						<div class="col-md-10 offset-md-1">
							<div class="vlt-stretch-block to-left vlt-devide-section">
								<div class="position-relative d-flex align-items-end justify-content-end">
									<!--Content slider-->
									<div class="vlt-content-slider "
										data-navigation-anchor=".vlt-careers-single-slider-anchor" data-gap=""
										data-loop="" data-speed="" data-autoplay="" data-autoplay-speed=""
										data-slides-centered="" data-slide-settings="{}" data-free-mode=""
										data-slider-offset="" data-mousewheel="">
										<div class="swiper-container">
											<div class="swiper-wrapper">
												<div class="swiper-slide"><img src="/static/img/about/4.jpg" alt=""
														loading="lazy"></div>
												<div class="swiper-slide"><img src="/static/img/about/2.jpg" alt=""
														loading="lazy"></div>
												<div class="swiper-slide"><img src="/static/img/about/3.jpg" alt=""
														loading="lazy"></div>
														<div class="swiper-slide"><img src="/static/img/about/1.jpg" alt=""
															loading="lazy"></div>
											</div>
										</div>
									</div>
									<!--Slider controls-->
									<div
										class="vlt-slider-controls vlt-slider-controls--style-3 vlt-careers-single-slider-anchor has-white-color has-black-background-color position-absolute b-0 r-0">
										<div class="vlt-swiper-button-prev">Prev
										</div><span class="sep">|</span>
										<div class="vlt-swiper-button-next">Next
										</div>
									</div>
								</div>
							</div>
							<div class="vlt-gap-120"></div>
						</div>
						<!-- who we are -->
						<div class="vlt-gap-120"></div>
						<div class="container">
							<div class="row">
								<div class="col-md-11 offset-md-1">
									<!--Animated block-->
									<div class="vlt-animated-block" data-aos="fade" data-aos-delay="0"><span
											class="vlt-display-1 has-primary-color">ABOUT</span>
									</div>
									<div class="vlt-gap-30"></div>
								</div>
								<div class="col-md-4 offset-md-1">
									<!--Animated block-->
									<div class="vlt-animated-block" data-aos="fade" data-aos-delay="0">
										<!--Section title-->
										<div class="vlt-section-title vlt-section-title--style-1">
											<h2 class="vlt-section-title__title" style="color: #bbb;">OUR TEAM</h2>
											<h4 class="vlt-section-title__title" style="color: #bbb;">Who we are:
											</h4>
										</div>
									</div>
									<div class="vlt-gap-40--sm"></div>
								</div>
								<div class="col-md-7">
									<!--Animated block-->
									<div class="vlt-animated-block" data-aos="fade" data-aos-delay="100">
										<p class="fz-3 text-justify" style="text-indent: 40px;">
											We are currently a team of three passionate human beings -with many more helping hands when needed- with a soft spot for creating websites and applications, writing informative copy, SEO optimization, and digital marketing. The websites and applications we build are both functional and aesthetically pleasing.
We have a combined six years of experience in professional website development and programming. Our copywriter has two years of experience and writes professional SEO-friendly copy with an emphasis on simple explanations and understandability. At the heart of our business model is the ambition to blend a readiness for meaningful human interaction with the aspiration for top-quality and highly effective service provision.
										</p>

									</div>
								</div>
							</div>
						</div>

						<div class="vlt-gap-50"></div>

						<div class="col-md-11 offset-md-1">
							<!--Animated block-->
							<div class="vlt-animated-block" data-aos="fade" data-aos-delay="0">
								<div class="has-light-gray-color" style="opacity: .16;">
									<!--Mission-->
									<div class="vlt-stroke-text vlt-stroke-text--lg">01
									</div>
								</div>
								<h5 class="has-white-color negative-top-offset-lg">Our mission</h5>
								<div class="vlt-gap-40"></div>
								<p class="text-justify">
									Our mission is to provide customer-centric, result-oriented, cost-competitive, creative, and 
									functional IT solutions to our clients. We follow a set of principles in delivering our mission:

								<ul class="vlt-styled-list list-about">
									<li>We get to know the needs, and requirements of our customers to perfection
									</li>
									<li>We harness technology to resolve the identified needs, and problems</li>
									<li>We seek new opportunities to maximize business value, drive growth, and ensure sustainability
									</li>
									<li>We empower our clients to respond swiftly, and effectively to changing industry dynamics
										</li>
									<li>We enable our customers to be flexible, and competitive by leveraging innovative technologies
										</li>
									<li>We stand by our clients along the journey of bringing great products to the market and achieving success
									</li>

								</ul>
								</p>
							</div>
							<div class="vlt-gap-60--sm"></div>
						</div>
						<div class="vlt-gap-400"></div>

						<div class="col-md-11 offset-md-1">
							<!--Animated block-->
							<div class="vlt-animated-block" data-aos="fade" data-aos-delay="0">
								<div class="has-light-gray-color" style="opacity: .16;">
									<!--Vision-->
									<div class="vlt-stroke-text vlt-stroke-text--lg">02
									</div>
								</div>
								<h5 class="has-white-color negative-top-offset-lg">Our vision</h5>
								<div class="vlt-gap-40"></div>
								<p class="text-justify">
									Our vision is focused on constant innovation and growth. At the core of our company is an ambition to 
									offer superior quality services, and solutions. We want to be globally recognized for our integrity, 
									commitment, quality, transparency, and customer-centricity.
								</p>
							</div>
							<div class="vlt-gap-60--sm"></div>
						</div>
					</div>
				</div>
				<div class="vlt-gap-120"></div>
			</section>


			<!--=============== our skills ===============-->
			<section class="position-relative">
				<!--Particle image--><img class="vlt-particle" src="/static/img/root/about-us-red-shape.png"
					data-animation-name="fadeInLeft" alt=""
					style="position: absolute; top: 0; left: 0; max-width: 260px;" loading="lazy">
				<div class="vlt-gap-120"></div>
				<div class="container">
					<div class="row">
						<div class="col-md-10 offset-md-1">
							<div class="text-center">
								<!--Animated block-->
								<div class="vlt-animated-block" data-aos="fade" data-aos-delay="0">
									<!--Section title-->
									<div class="vlt-section-title vlt-section-title--style-1">
										<h2 class="vlt-section-title__title">Our Skills</h2>
									</div>
								</div>
							</div>
							<div class="vlt-gap-100"></div>
							<!--Animated block-->
							<div class="col-md-11 offset-md-1 ">
								<h5>Programing language :</h5>
								<p class="text-justify">
									Python- Flask- Next.JS- React- Node.JS- DJango- JavaScripit- Php- jQuery- bootstrap-
									Html- CSS3- SCSS- SQL- GraphQL- MySQL- PostgreSQL <br />
									<b>CMS: </b>Strapi- Wordpress- Shopify- Droopal
								</p>

