---
import BaseLayout from '../layouts/BaseLayout.astro';

// Public site key — exposed at build time. The "always pass" CF dummy key
// (`1x00000000000000000000AA`) is the dev/test default; real key set via
// PUBLIC_TURNSTILE_SITE_KEY in CF Pages env.
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA';
---

<BaseLayout
  title="Contact — AH-design"
  htmlClass="no-js vlt-is--contact-01 vlt-is--header-fullscreen vlt-is--footer-style-1 vlt-is--footer-fixed"
>
  <Fragment slot="head">
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
  </Fragment>

  <div class="vlt-site-overlay"></div>

  <main class="vlt-main">
    <div class="vlt-page-content">
      <div class="vlt-page-title vlt-page-title--style-4">
        <div class="container">
          <div class="row">
            <div class="col-md-7 offset-md-1">
              <h1 class="vlt-page-title__title">We'd love to hear from you</h1>
            </div>
            <div class="col-md-3">
              <div
                class="vlt-page-title__phantom-title lax"
                data-lax-translate-x="0 0, vw (vw*0.5)"
                data-lax-opacity="1 1, 250 0"
                data-lax-anchor=".vlt-page-title">
                Contact
              </div>
            </div>
            <div class="col-md-7 offset-md-1">
              <p class="vlt-page-title__subtitle">
                You can contact us by filling out the form or reach us directly by calling the
                number below. We offer complimentary advice in the initial contact phase.
              </p>
            </div>
          </div>
        </div>
      </div>
      <div id="content"></div>

      <section>
        <div class="vlt-gap-100"></div>
        <div class="container position-relative">
          <form
            class="vlt-contact-form vlt-contact-form--style-1 has-extra-light-gray-background-color"
            novalidate="novalidate"
            id="contactsubmit"
            method="post"
            action="/api/contact"
          >
            <div class="vlt-form-row two-col">
              <div class="vlt-form-group">
                <input class="vlt-form-control" type="text" name="name" required="required" placeholder=" " />
                <label class="vlt-form-label">Your name*</label>
              </div>
              <div class="vlt-form-group">
                <input class="vlt-form-control" type="email" name="email" required="required" placeholder=" " />
                <label class="vlt-form-label">Email address*</label>
              </div>
            </div>
            <div class="vlt-form-row two-col">
              <div class="vlt-form-group">
                <input class="vlt-form-control" type="tel" name="phone" placeholder=" " />
                <label class="vlt-form-label">Phone number</label>
              </div>
              <div class="vlt-form-group">
                <input class="vlt-form-control" type="text" name="company" placeholder=" " />
                <label class="vlt-form-label">Company</label>
              </div>
            </div>
            <div class="vlt-form-group">
              <input class="vlt-form-control" type="text" name="title" required="required" placeholder=" " />
              <label class="vlt-form-label">Title*</label>
            </div>
            <div class="vlt-form-group">
              <textarea class="vlt-form-control" name="message" rows="5" placeholder=" "></textarea>
              <label class="vlt-form-label">Message*</label>
            </div>

            {/* Honeypot — bots fill it, real users never see it. Off-screen via inline style + tabindex/autocomplete to keep keyboard users / password managers away. */}
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;"
            />

            {/* Turnstile — invisible challenge, server-verified */}
            <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-size="invisible"></div>

            <div class="message success">Your message is successfully sent...</div>
            <div class="message danger">Sorry something went wrong!</div>
            <div class="vlt-gap-40"></div>
            <div class="text-center">
              <button class="vlt-btn vlt-btn--secondary vlt-btn--lg">Submit</button>
            </div>
            <p id="msgoutput" style="display: none;"></p>
          </form>
        </div>
      </section>

      <section>
        <div class="vlt-gap-120"></div>
        <div class="container">
          <div class="row">
            <div class="col-md-4">
              <div class="vlt-simple-image">
                <div class="vlt-simple-image__mask" data-aos="image-mask-animation" data-aos-delay="0">
                  <div class="inside"></div>
                </div>
                <img src="/static/img/4.png" alt="" loading="lazy" />
              </div>
              <div class="vlt-gap-35"></div>
              <div class="vlt-animated-block" data-aos="fade" data-aos-delay="0">
                <h5>Email:</h5>
                <div class="vlt-gap-20"></div>
                <p class="lh-2"><a href="mailto:info@ahdesign.website">info@ahdesign.website</a></p>
              </div>
              <div class="vlt-gap-60--sm"></div>
            </div>
            <div class="col-md-4">
              <div class="vlt-simple-image">
                <div class="vlt-simple-image__mask" data-aos="image-mask-animation" data-aos-delay="100">
                  <div class="inside"></div>
                </div>
                <img src="/static/img/6.png" alt="" loading="lazy" />
              </div>
              <div class="vlt-gap-35"></div>
              <div class="vlt-animated-block" data-aos="fade" data-aos-delay="100">
                <h5>Phone:</h5>
                <div class="vlt-gap-20"></div>
                <p class="lh-2"><a href="tel:+359886660034">(+359)- 88 666 0034</a></p>
              </div>
              <div class="vlt-gap-60--sm"></div>
            </div>
            <div class="col-md-4">
              <div class="vlt-simple-image">
                <div class="vlt-simple-image__mask" data-aos="image-mask-animation" data-aos-delay="200">
                  <div class="inside"></div>
                </div>
                <img src="/static/img/5.png" alt="" loading="lazy" />
              </div>
              <div class="vlt-gap-35"></div>
              <div class="vlt-animated-block" data-aos="fade" data-aos-delay="200">
                <h5><a href="#">Working hours:</a></h5>
                <div class="vlt-gap-20"></div>
                <p class="lh-2"><a href="">Monday - Friday, 10am - 6pm</a></p>
              </div>
            </div>
          </div>
        </div>
        <div class="vlt-gap-120"></div>
      </section>
    </div>
  </main>

  <Fragment slot="js">
    <script is:inline define:vars={{ formId: 'contactsubmit', endpoint: '/api/contact' }}>
      const form = document.getElementById(formId);
      const output = document.getElementById('msgoutput');
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          output.style.display = 'block';
          output.style.color = '#333';
          output.innerHTML = ' Sending...';

          const data = new FormData(form);
          try {
            const res = await fetch(endpoint, { method: 'POST', body: data });
            const json = await res.json().catch(() => ({}));
            if (res.ok && json.success) {
              output.style.color = 'green';
              output.innerHTML = ' Your message has been sent';
              form.reset();
              if (window.turnstile) window.turnstile.reset();
            } else {
              output.style.color = 'red';
              output.innerHTML = ' Something went wrong, please try again';
            }
          } catch (_err) {
            output.style.color = 'red';
            output.innerHTML = ' Something went wrong, please try again';
          }
        });
      }
    </script>
  </Fragment>
</BaseLayout>
