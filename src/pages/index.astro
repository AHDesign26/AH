---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.published_date.localeCompare(a.data.published_date))
  .slice(0, 3)
  .map((p) => p.data);
